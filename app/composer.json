{
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-ctype": "*",
        "ext-http": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.0",
        "doctrine/persistence": "^3.3",
        "dragonmantank/cron-expression": "^3.4",
        "gesdinet/jwt-refresh-token-bundle": "^1.3",
        "lexik/jwt-authentication-bundle": "^3.0",
        "php-amqplib/rabbitmq-bundle": "^2.8",
        "phpdocumentor/reflection-docblock": "^5.4",
        "predis/predis": "^2.3",
        "ruflin/elastica": "^7.3",
        "snc/redis-bundle": "^4.10",
        "symfony/asset": "7.2.*",
        "symfony/console": "7.2.*",
        "symfony/doctrine-bridge": "7.2.*",
        "symfony/dotenv": "7.2.*",
        "symfony/expression-language": "^7.2",
        "symfony/flex": "^2.4",
        "symfony/form": "7.2.*",
        "symfony/framework-bundle": "7.2.*",
        "symfony/http-client": "7.2.*",
        "symfony/http-foundation": "7.2.*",
        "symfony/messenger": "7.2.*",
        "symfony/mime": "7.2.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/password-hasher": "^7.2",
        "symfony/property-access": "7.2.*",
        "symfony/property-info": "7.2.*",
        "symfony/rate-limiter": "7.2.*",
        "symfony/scheduler": "7.2.*",
        "symfony/security-bundle": "7.2.*",
        "symfony/serializer": "7.2.*",
        "symfony/stopwatch": "7.2.*",
        "symfony/twig-bundle": "7.2.*",
        "symfony/validator": "7.2.*",
        "symfony/web-profiler-bundle": "7.2.*",
        "symfony/webpack-encore-bundle": "^2.0",
        "symfony/yaml": "7.2.*",
        "twig/extra-bundle": "^3.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.0",
        "doctrine/doctrine-fixtures-bundle": "^3.6",
        "jetbrains/phpstorm-attributes": "^1.0",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "7.2.*",
        "symfony/css-selector": "7.2.*",
        "symfony/maker-bundle": "^1.60",
        "symfony/phpunit-bridge": "^7.2"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "exclude-from-classmap": [
            "/migrations/",
            "/src/Traits/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "/migrations/",
            "/tests/Traits/"
        ]
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "tests-app": "phpunit --colors=always tests"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        }
    }
}
